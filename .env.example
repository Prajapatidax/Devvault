
GEMINI_API_KEY="MY_GEMINI_API_KEY"


JWT_SECRET="YOUR_JWT_SECRET_KEY"

# ENCRYPTION_KEY: Secret key for encrypting stored secrets securely (32 characters recommended)
ENCRYPTION_KEY="YOUR_ENCRYPTION_SECRET_KEY_FOR_VAULT"

# DATABASE_URL: PostgreSQL connection string (Supabase)
# Leave empty or omit to fallback to local JSON database storage (db.json)
DATABASE_URL="postgresql://postgres:[password]@[host]:[port]/[database]"

# Brevo SMTP Configuration
SMTP_SERVER="smtp-relay.brevo.com"
SMTP_PORT=587
SMTP_USERNAME="your-brevo-login-email@example.com"
SMTP_PASSWORD="your-brevo-smtp-key"
MAIL_FROM="DevVault <no-reply@devvault.com>"

# OTP Verification Configurations
OTP_EXPIRY_MINUTES=10
OTP_LENGTH=6
RESEND_WAIT_SECONDS=60
MAX_OTP_ATTEMPTS=5



